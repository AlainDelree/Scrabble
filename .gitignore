# Environnements virtuels
venv/
.venv/

# Sorties de build / packaging (PyInstaller)
build/
dist/
*.spec

# Caches Python
__pycache__/
*.py[cod]

# Configuration locale auto-générée (recréée par scrabble.config)
config.json

# Dictionnaires tiers (ODS8, Hunspell fr-toutesvariantes) : déposés
# manuellement, jamais commités (licence floue). On garde uniquement le README.
data/dictionnaire/*
!data/dictionnaire/README.md

# Base SQLite des parties (persistance : historique + reprise) — jamais commitée
data/parties.db
data/*.db

# Photos de plateaux réels fournies pour inspiration visuelle (non commitées)
Exemples plateau/

# Divers
.pytest_cache/
tmp_diag_wiktionnaire/
