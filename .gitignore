# Environnements virtuels
venv/
.venv/
.venv_build/

# Sorties de build / packaging (PyInstaller)
build/
dist/
*.spec
# Exception : le .spec de l'exécutable Windows (issue #154) est committé
# volontairement, contrairement aux artefacts *.spec habituels (temporaires).
!scrabble.spec

# Caches Python
__pycache__/
*.py[cod]

# Configuration locale auto-générée (recréée par scrabble.config)
config.json

# Dictionnaires tiers (ODS8, Hunspell fr-toutesvariantes) : déposés
# manuellement, jamais commités (licence floue). On garde uniquement le README.
data/dictionnaire/*
!data/dictionnaire/README.md

# Base SQLite des parties (persistance : historique + reprise) — jamais commitée
data/parties.db
data/*.db

# Journaux de diagnostic par session (scrabble.journal) — jamais commités
logs/

# Photos de plateaux réels fournies pour inspiration visuelle (non commitées)
Exemples plateau/

# Installeur Windows (Inno Setup, issue #217) : setup.exe générés jamais
# commités (volumineux, régénérables via installeur\scrabble.iss) — seul le
# script .iss et le README du dossier sont suivis. Voir installeur\README.md.
installeur/output/

# Outils de build locaux à la machine CCW (ex. Inno Setup portable) — jamais
# commités, jamais nécessaires ailleurs que sur la machine qui compile.
.tools/

# Divers
.pytest_cache/
tmp_diag_wiktionnaire/
